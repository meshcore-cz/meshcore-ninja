{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meshcore-atlas/schema/changelog.schema.json",
  "title": "Changelog",
  "description": "Cached release history for a firmware. Usually generated by scripts/update-changelogs.js, but may be hand-written when source is 'manual'.",
  "type": "object",
  "additionalProperties": false,
  "required": ["releases"],
  "properties": {
    "source": { "enum": ["github", "manual", "script"] },
    "repo": { "type": "string" },
    "updatedAt": { "type": "string" },
    "releases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version"],
        "properties": {
          "version": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "datetime": { "type": "string", "description": "Full ISO 8601 timestamp." },
          "date": { "type": "string", "description": "YYYY-MM-DD (manual fallback)." },
          "url": { "type": "string" },
          "prerelease": { "type": "boolean" },
          "notes": { "type": "string" },
          "notesUrl": { "type": "string", "description": "Where enriched notes were sourced from." }
        }
      }
    }
  }
}
