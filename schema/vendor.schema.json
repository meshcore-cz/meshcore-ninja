{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meshcore-atlas/schema/vendor.schema.json",
  "title": "Vendor",
  "description": "A hardware manufacturer. The id comes from the directory name, not this file.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "website": { "type": "string", "pattern": "^https?://" },
    "country": { "type": "string", "minLength": 1 },
    "logo": { "type": "string", "pattern": "\\.(svg|png|jpe?g|webp)$" },
    "description": { "type": "string" }
  }
}
